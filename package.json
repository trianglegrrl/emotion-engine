{
  "name": "openfeelz",
  "version": "2.0.0",
  "description": "Emotional model with personality-influenced decay, rumination, and multi-agent awareness for Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./mcp": "./dist/src/mcp/mcp-server.js"
  },
  "bin": {
    "openfeelz-mcp": "./dist/src/mcp/mcp-server.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "npx oxlint ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0"
  },
  "devDependencies": {
    "@sinclair/typebox": "^0.34.48",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/trianglegrrl/openfeelz.git"
  },
  "homepage": "https://github.com/trianglegrrl/openfeelz#readme",
  "bugs": {
    "url": "https://github.com/trianglegrrl/openfeelz/issues"
  },
  "keywords": [
    "claude-code",
    "emotion",
    "affective-computing",
    "personality",
    "ocean",
    "pad",
    "ai-agent",
    "mcp"
  ],
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    ".claude-plugin",
    "hooks",
    "commands"
  ],
  "prepublishOnly": "npm run build",
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.60.1"
  }
}
